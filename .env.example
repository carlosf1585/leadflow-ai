ENV=production
SECRET_KEY=change-me-to-long-random-string
ADMIN_TOKEN=change-me-admin-token

# Database (use Railway PostgreSQL URL)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Redis (use Railway Redis URL)
REDIS_URL=redis://default:pass@host:6379

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_SMART=gpt-4o

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password

# Google Maps
GOOGLE_MAPS_API_KEY=your-key

# Lead pricing
LEAD_PRICE_PLUMBING=35.0
LEAD_PRICE_ROOFING=45.0
LEAD_PRICE_HVAC=40.0
LEAD_PRICE_PEST_CONTROL=25.0
LEAD_PRICE_DENTAL=80.0
LEAD_PRICE_AUTO_ACCIDENT=300.0

# Cities and categories
DISCOVERY_CITIES=["New York","Los Angeles","Houston","Phoenix","Chicago"]
SERVICE_CATEGORIES=["plumber","roofer","hvac","pest control","dentist"]